# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to version control.

# --- Database ---
[neon]
database_url = "postgresql://user:password@host/dbname?sslmode=require"

# --- Admin users ---
# Comma-separated usernames that are granted admin access.
# These must also have is_admin=TRUE in the users table (set via grant_admin()).
# Leave empty to rely entirely on the DB is_admin flag.
ADMIN_USERS = ""

# --- Stripe ---
STRIPE_SECRET_KEY = "sk_live_..."
STRIPE_WEBHOOK_SECRET = "whsec_..."
STRIPE_PRICE_PRO = "price_..."
STRIPE_PRICE_PREMIUM = "price_..."

# --- App URLs (for billing redirects) ---
APP_SUCCESS_URL = "https://your-app.streamlit.app"
APP_CANCEL_URL = "https://your-app.streamlit.app"
APP_PORTAL_RETURN_URL = "https://your-app.streamlit.app/billing"

# --- Demo users (DISABLE IN PRODUCTION) ---
# ENABLE_DEMO_USERS = "0"
# DEMO_BASIC_PASSWORD = ""
# DEMO_PRO_PASSWORD = ""
# DEMO_PREMIUM_PASSWORD = ""
# DEMO_ADMIN_PASSWORD = ""
